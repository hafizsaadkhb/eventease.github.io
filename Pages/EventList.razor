@page "/"
@page "/events"

<PageTitle>Events</PageTitle>

<h1>Upcoming Events</h1>
<p>Browse upcoming events and open the details or registration pages.</p>

<div class="d-flex flex-column gap-4">
    @foreach (var eventItem in events)
    {
        <div>
            <EventCard Model="eventItem" />
            <div class="mt-2">
                <NavLink class="btn btn-outline-primary me-2" href="@($"events/{eventItem.Id}")">Details</NavLink>
                <NavLink class="btn btn-primary" href="@($"registration/{eventItem.Id}")">Register</NavLink>
            </div>
        </div>
    }
</div>

@code {
    private List<EventModel> events = EventModel.GetSampleEvents();
}
