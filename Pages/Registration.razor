@page "/registration/{eventId:int}"
@inject EventEase.Services.SessionService SessionService
@inject EventEase.Services.AttendanceService AttendanceService

@using System.ComponentModel.DataAnnotations
<PageTitle>Registration</PageTitle>

@if (selectedEvent == null)
{
    <h1>Event not found</h1>
    <p>Return to the event list to choose a different event.</p>
    <NavLink class="btn btn-link" href="/events">Back to events</NavLink>
}
else
{
    <h1>Register for @selectedEvent.Name</h1>
    <p>@selectedEvent.Date.ToString("MMMM dd, yyyy") - @selectedEvent.Location</p>

    @if (isSubmitted)
    {
        <div class="alert alert-success" role="alert">
            Thanks, @registrationModel.Name! Your registration has been submitted.
        </div>
    }

    <EditForm Model="registrationModel" OnValidSubmit="HandleSubmit" class="mt-3">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label class="form-label" for="name">Full name</label>
            <InputText id="name" class="form-control" @bind-Value="registrationModel.Name" />
            <ValidationMessage For="@(() => registrationModel.Name)" />
        </div>

        <div class="mb-3">
            <label class="form-label" for="email">Email</label>
            <InputText id="email" class="form-control" @bind-Value="registrationModel.Email" />
            <ValidationMessage For="@(() => registrationModel.Email)" />
        </div>

        <div class="mb-3">
            <label class="form-label" for="notes">Notes</label>
            <InputTextArea id="notes" class="form-control" @bind-Value="registrationModel.Notes" />
        </div>

        <button class="btn btn-primary" type="submit">Submit registration</button>
    </EditForm>
}

@code {
    [Parameter]
    public int EventId { get; set; }

    private EventModel? selectedEvent;

    private RegistrationModel registrationModel = new();
    private bool isSubmitted;

    protected override async Task OnParametersSetAsync()
    {
        await SessionService.InitializeAsync();
        await AttendanceService.InitializeAsync();

        selectedEvent = EventModel.GetSampleEvents()
            .FirstOrDefault(item => item.Id == EventId);

        if (SessionService.Current != null)
        {
            registrationModel.Name = SessionService.Current.Name;
            registrationModel.Email = SessionService.Current.Email;
        }
    }

    private async Task HandleSubmit()
    {
        // persist session
        await SessionService.SetCurrentAsync(registrationModel.Name, registrationModel.Email);

        // persist registration
        var record = new EventEase.Models.RegistrationRecord
        {
            EventId = EventId,
            Name = registrationModel.Name,
            Email = registrationModel.Email,
            Notes = registrationModel.Notes,
            RegisteredAtUtc = DateTime.UtcNow
        };

        await AttendanceService.AddAsync(record);
        isSubmitted = true;
    }

    public class RegistrationModel
    {
        [Required]
        public string Name { get; set; } = string.Empty;

        [Required]
        [EmailAddress]
        public string Email { get; set; } = string.Empty;

        public string Notes { get; set; } = string.Empty;
    }
}
